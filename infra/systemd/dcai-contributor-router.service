[Unit]
Description=DCAI Contributor RPC canary router
After=network-online.target nginx.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/dcai/rewards/monitor
ExecStart=/usr/bin/node /opt/dcai/rewards/monitor/contributor-router.mjs
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/dcai/rewards/monitor

[Install]
WantedBy=multi-user.target
